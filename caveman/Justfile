alias repl := nrepl

# Shows available recipes
help:
  just --list

run:
  clojure -M -m example.main

nrepl:
  clojure -M:dev:repl/nrepl

conjure:
  clojure -M:dev:repl/conjure

rebel:
  clojure -M:dev:repl/rebel

nrebel *FLAGS: 
  clojure -M:dev:repl/nrebel -p {{read(".nrepl-port")}} {{FLAGS}}

check:
  clojure -T:cljfmt check src dev test

fix: 
  clojure -T:cljfmt fix src dev test

# Adding '-' before the command ignores error exit codes
lint:
  -clojure -M:lint -m clj.kondo.main --lint .

test:
  -clojure -M:dev -m kaocha.runner
